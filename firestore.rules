rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: nome, senha
    //
    // Collection: clientes
    // Fields: codigo, nome, whatsapp, telefone, instagram, status, etc.
    //
    // Collection: materiasPrimas
    // Fields: codigo, nome, largura, altura, custoChapa, etc.
    //
    // Collection: produtosPapelaria
    // Fields: codigo, nome, tempoFabricacao, custoFabricacao, etc.
    //
    // Collection: produtosLaser
    // Fields: codigo, nome, materiaPrimaCodigo, etc.
    //
    // Collection: custosFixos
    // Fields: id, nome, valor, dataUltimaAlteracao
    //
    // Collection: configuracoes
    // Fields: custoHoraMaquina, dataUltimaAlteracaoMaquina
    //
    // Collection: orcamentos
    // Fields: id, clienteCodigo, itens, totalGeral, status, etc.
    //
    // Collection: pedidos
    // Fields: id, clienteCodigo, itens, totalGeral, status, etc.
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "fflana16@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['nome', 'senha']) &&
             data.nome is string && data.nome.size() > 0 && data.nome.size() < 100 &&
             data.senha is string && data.senha.size() >= 6;
    }

    function isValidCliente(data) {
      return hasRequiredFields(['codigo', 'nome']) &&
             data.codigo is string && data.codigo.size() > 0 &&
             data.nome is string && data.nome.size() > 0 && data.nome.size() < 200;
    }

    function isValidMateriaPrima(data) {
      return hasRequiredFields(['codigo', 'nome']) &&
             data.codigo is string && data.codigo.size() > 0 &&
             data.nome is string && data.nome.size() > 0;
    }

    function isValidOrcamento(data) {
      return hasRequiredFields(['id', 'clienteCodigo', 'itens']) &&
             data.id is string && data.clienteCodigo is string &&
             data.itens is list;
    }

    function isValidPedido(data) {
      return hasRequiredFields(['id', 'clienteCodigo', 'itens']) &&
             data.id is string && data.clienteCodigo is string &&
             data.itens is list;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read: if true;
      allow create, update: if isValidUser(request.resource.data);
      allow delete: if true; // Custom login handles this in UI
    }

    match /clientes/{clienteId} {
      allow read: if true;
      allow create, update: if isValidCliente(request.resource.data);
      allow delete: if true;
    }

    match /materiasPrimas/{mpId} {
      allow read: if true;
      allow create, update: if isValidMateriaPrima(request.resource.data);
      allow delete: if true;
    }

    match /produtosPapelaria/{pId} {
      allow read: if true;
      allow create, update: if hasRequiredFields(['codigo', 'nome']);
      allow delete: if true;
    }

    match /produtosLaser/{pId} {
      allow read: if true;
      allow create, update: if hasRequiredFields(['codigo', 'nome']);
      allow delete: if true;
    }

    match /custosFixos/{cfId} {
      allow read: if true;
      allow create, update: if hasRequiredFields(['id', 'nome', 'valor']);
      allow delete: if true;
    }

    match /configuracoes/{cId} {
      allow read: if true;
      allow create, update: if true;
      allow delete: if true;
    }

    match /orcamentos/{oId} {
      allow read: if true;
      allow create, update: if isValidOrcamento(request.resource.data);
      allow delete: if true;
    }

    match /pedidos/{pId} {
      allow read: if true;
      allow create, update: if isValidPedido(request.resource.data);
      allow delete: if true;
    }
  }
}
